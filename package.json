{
  "name": "cmsis-dev",
  "displayName": "CMSIS-Dev",
  "description": "CMSIS development helper extension with AI workflows and an MCP server.",
  "version": "0.0.1",
  "publisher": "cmsis-dev",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:cmsisDev.actions",
    "onView:cmsisDev.workflows",
    "onView:cmsisDev.runs",
    "onCommand:cmsisDev.runAction",
    "onCommand:cmsisDev.initializeWorkflows",
    "onCommand:cmsisDev.refreshWorkflows",
    "onCommand:cmsisDev.refreshRuns",
    "onCommand:cmsisDev.deleteRuns",
    "onCommand:cmsisDev.selectAiBackend",
    "onCommand:cmsisDev.selectLanguageModel",
    "onCommand:cmsisDev.manageLanguageModelProvider",
    "onCommand:cmsisDev.refreshLanguageModelProvider",
    "onCommand:cmsisDev.setGitHubToken",
    "onCommand:cmsisDev.clearGitHubToken",
    "onCommand:cmsisDev.openReasoningForActiveOutput",
    "onCommand:cmsisDev.postCommentForActiveOutput",
    "onCommand:cmsisDev.openPrForActiveOutput",
    "onCommand:cmsisDev.openIssueForActiveOutput",
    "onCommand:cmsisDev.openChatForActiveOutput",
    "onCommand:cmsisDev.submitPrForActiveOutput"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cmsisDev",
          "title": "CMSIS-Dev",
          "icon": "media/cmsis-dev.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "cmsisDev.runAction",
        "title": "CMSIS-Dev: Run AI Action"
      },
      {
        "command": "cmsisDev.initializeWorkflows",
        "title": "CMSIS-Dev: Create Workflow Overrides"
      },
      {
        "command": "cmsisDev.selectAiBackend",
        "title": "CMSIS-Dev: Set AI Backend",
        "icon": "$(hubot)"
      },
      {
        "command": "cmsisDev.selectLanguageModel",
        "title": "CMSIS-Dev: Set VS Code Model",
        "icon": "$(pulse)"
      },
      {
        "command": "cmsisDev.manageLanguageModelProvider",
        "title": "CMSIS-Dev: Manage Language Model Provider",
        "icon": "$(gear)"
      },
      {
        "command": "cmsisDev.refreshLanguageModelProvider",
        "title": "CMSIS-Dev: Refresh Language Model Provider",
        "icon": "$(refresh)"
      },
      {
        "command": "cmsisDev.refreshRuns",
        "title": "CMSIS-Dev: Refresh Runs",
        "icon": "$(refresh)"
      },
      {
        "command": "cmsisDev.deleteRuns",
        "title": "CMSIS-Dev: Delete Runs",
        "icon": "$(trash)"
      },
      {
        "command": "cmsisDev.refreshWorkflows",
        "title": "CMSIS-Dev: Refresh Workflows",
        "icon": "$(refresh)"
      },
      {
        "command": "cmsisDev.setGitHubToken",
        "title": "CMSIS-Dev: Set GitHub Token"
      },
      {
        "command": "cmsisDev.clearGitHubToken",
        "title": "CMSIS-Dev: Clear GitHub Token"
      },
      {
        "command": "cmsisDev.openReasoningForActiveOutput",
        "title": "CMSIS-Dev: Open Reasoning",
        "icon": "$(file-code)"
      },
      {
        "command": "cmsisDev.postCommentForActiveOutput",
        "title": "CMSIS-Dev: Post Comment",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "cmsisDev.openPrForActiveOutput",
        "title": "CMSIS-Dev: Open PR",
        "icon": "$(link-external)"
      },
      {
        "command": "cmsisDev.openIssueForActiveOutput",
        "title": "CMSIS-Dev: Open Issue",
        "icon": "$(link-external)"
      },
      {
        "command": "cmsisDev.openChatForActiveOutput",
        "title": "CMSIS-Dev: Open in Chat",
        "icon": "$(send)"
      },
      {
        "command": "cmsisDev.submitPrForActiveOutput",
        "title": "CMSIS-Dev: Submit PR",
        "icon": "$(git-pull-request-create)"
      }
    ],
    "views": {
      "cmsisDev": [
        {
          "id": "cmsisDev.actions",
          "name": "Actions"
        },
        {
          "id": "cmsisDev.runs",
          "name": "Runs"
        },
        {
          "id": "cmsisDev.workflows",
          "name": "Workflows",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cmsisDev.selectAiBackend",
          "when": "view == cmsisDev.actions",
          "group": "navigation"
        },
        {
          "command": "cmsisDev.selectLanguageModel",
          "when": "view == cmsisDev.actions",
          "group": "navigation"
        },
        {
          "command": "cmsisDev.manageLanguageModelProvider",
          "when": "view == cmsisDev.actions",
          "group": "navigation"
        },
        {
          "command": "cmsisDev.initializeWorkflows",
          "when": "view == cmsisDev.workflows",
          "group": "navigation"
        },
        {
          "command": "cmsisDev.refreshWorkflows",
          "when": "view == cmsisDev.workflows",
          "group": "navigation"
        },
        {
          "command": "cmsisDev.refreshRuns",
          "when": "view == cmsisDev.runs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cmsisDev.deleteRuns",
          "when": "view == cmsisDev.runs && viewItem == cmsisDev.runOutput",
          "group": "inline"
        },
        {
          "command": "cmsisDev.deleteRuns",
          "when": "view == cmsisDev.runs && viewItem == cmsisDev.runOutput",
          "group": "2_cmsisDev@1"
        }
      ],
      "editor/title": [
        {
          "command": "cmsisDev.openPrForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenPr",
          "group": "navigation@9"
        },
        {
          "command": "cmsisDev.openIssueForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenIssue",
          "group": "navigation@9"
        },
        {
          "command": "cmsisDev.openReasoningForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenReasoning",
          "group": "navigation@10"
        },
        {
          "command": "cmsisDev.postCommentForActiveOutput",
          "when": "cmsisDev.activeOutput.canPostComment",
          "group": "navigation@11"
        },
        {
          "command": "cmsisDev.openChatForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenChat",
          "group": "navigation@12"
        },
        {
          "command": "cmsisDev.submitPrForActiveOutput",
          "when": "cmsisDev.activeOutput.canSubmitPr",
          "group": "navigation@13"
        }
      ],
      "editor/title/context": [
        {
          "command": "cmsisDev.openPrForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenPr",
          "group": "2_cmsisDev@1"
        },
        {
          "command": "cmsisDev.openIssueForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenIssue",
          "group": "2_cmsisDev@2"
        },
        {
          "command": "cmsisDev.openReasoningForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenReasoning",
          "group": "2_cmsisDev@3"
        },
        {
          "command": "cmsisDev.postCommentForActiveOutput",
          "when": "cmsisDev.activeOutput.canPostComment",
          "group": "2_cmsisDev@4"
        },
        {
          "command": "cmsisDev.openChatForActiveOutput",
          "when": "cmsisDev.activeOutput.canOpenChat",
          "group": "2_cmsisDev@5"
        },
        {
          "command": "cmsisDev.submitPrForActiveOutput",
          "when": "cmsisDev.activeOutput.canSubmitPr",
          "group": "2_cmsisDev@6"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "cmsis-dev.chat",
        "name": "cmsisdev",
        "fullName": "CMSIS-Dev",
        "description": "Run CMSIS-Dev workflows inside VS Code Chat.",
        "isSticky": true,
        "commands": [
          {
            "name": "run",
            "description": "Choose and run any CMSIS-Dev workflow."
          },
          {
            "name": "review-pr",
            "description": "Review a pull request."
          },
          {
            "name": "review-changes",
            "description": "Review local workspace changes."
          },
          {
            "name": "create-pr",
            "description": "Draft a pull request from local changes."
          },
          {
            "name": "explain-issue",
            "description": "Explain a GitHub issue."
          }
        ]
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "cmsis-dev-openai-proxy",
        "displayName": "CMSIS-Dev Proxy Models",
        "managementCommand": "cmsisDev.manageLanguageModelProvider"
      }
    ],
    "configuration": {
      "title": "CMSIS-Dev",
      "properties": {
        "cmsisDev.workflowConfigPath": {
          "type": "string",
          "default": ".cmsis-dev/workflows",
          "description": "Relative path to the workflow configuration file or directory."
        },
        "cmsisDev.aiBackend": {
          "type": "string",
          "enum": [
            "vscodeLm",
            "codexCli"
          ],
          "default": "vscodeLm",
          "description": "How CMSIS-Dev should execute AI workflows."
        },
        "cmsisDev.languageModelSelector": {
          "type": "object",
          "default": {},
          "markdownDescription": "Optional VS Code language model selector for CMSIS-Dev actions. Use the command palette action to populate this setting."
        },
        "cmsisDev.languageModelProvider.baseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "OpenAI-compatible `v1` base URL used by the CMSIS-Dev language model provider for `/models` and `/chat/completions`."
        },
        "cmsisDev.languageModelProvider.defaultMaxInputTokens": {
          "type": "number",
          "default": 128000,
          "description": "Fallback maximum input token count used when the provider model catalog does not report one."
        },
        "cmsisDev.languageModelProvider.defaultMaxOutputTokens": {
          "type": "number",
          "default": 16384,
          "description": "Fallback maximum output token count used when the provider model catalog does not report one."
        },
        "cmsisDev.codexModel": {
          "type": "string",
          "default": "",
          "description": "Optional Codex model override when the AI backend is set to codexCli."
        },
        "cmsisDev.codexReasoningEffort": {
          "type": "string",
          "default": "",
          "description": "Optional Codex reasoning effort override when the AI backend is set to codexCli."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "vscode:prepublish": "npm run compile && npm run build:mcp"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/vscode": "^1.125.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  }
}
